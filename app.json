{
  "package_id": "com.juanmotz.displayplusmusic.hybrid",
  "edition": "202601",
  "name": "DisplayPlus Music",
  "author": "oliemanq",
  "version": "2.2.4",
  "min_app_version": "2.1.0",
  "min_sdk_version": "0.0.9",
  "entrypoint": "index.html",
  "tagline": "Music player for Even Hub",
  "description": "Media player for the Even Hub, displays progress and lyrics from multiple sources across devices.",
  "permissions": [
    {
      "name": "network",
      "desc": "This app needs to access the network in order to get music information and lyrics.",
      "whitelist": [
        "https://oliemanq.github.io/DisplayPlusMusic",
        "https://oliemanq.github.io/DisplayPlusMusic/",
        "https://accounts.spotify.com/authorize",
        "https://accounts.spotify.com/api/token",
        "https://api.spotify.com/v1/",
        "https://api.spotify.com/v1/me/player",
        "https://api.spotify.com/v1/me/player/queue",
        "https://api.spotify.com/v1/me/player/play",
        "https://api.spotify.com/v1/me/player/pause",
        "https://api.spotify.com/v1/me/player/next",
        "https://api.spotify.com/v1/me/player/previous",
        "https://api.spotify.com/v1/me/playlists",
        "https://api.spotify.com/v1/playlists",
        "https://i.scdn.co",
        "https://lrclib.net/api/get"
      ]
    }
  ],
  "supported_languages": [
    "en"
  ]
}




